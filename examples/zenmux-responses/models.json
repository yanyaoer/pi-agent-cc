{
  "$comment": "Install at ~/.pi/agent/models.json (or merge into existing). Registers ZenMux as an OpenAI Responses API gateway. Requires ZENMUX_API_KEY env.",
  "providers": {
    "zenmux-openai": {
      "baseUrl": "https://zenmux.ai/api/v1",
      "api": "openai-responses",
      "apiKey": "ZENMUX_API_KEY",
      "authHeader": true,
      "models": [
        {
          "id": "openai/gpt-5.5-pro",
          "name": "GPT-5.5 Pro (via ZenMux)",
          "reasoning": true,
          "input": ["text", "image"],
          "contextWindow": 400000,
          "maxTokens": 128000
        }
      ]
    }
  }
}
